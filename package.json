{
  "name": "ife",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:web": "turbo dev --filter=@ife/web",
    "dev:api": "turbo dev --filter=@ife/api",
    "workers:start": "cd services/workers && python run_workers.py",
    "workers:test": "cd services/workers && python -m pytest tests/",
    "db:migrate": "cd apps/api && pnpm run db:migrate",
    "validate": "cd services/workers && python scripts/validate_scoring.py"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
