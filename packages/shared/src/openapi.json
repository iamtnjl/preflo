    "/api/feedback": {
      "post": {
        "tags": [
          "Feedback"
        ],
        "description": "Submit outcome feedback for a scored keyword",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "keyword_slug",
                  "actual_result"
                ],
                "properties": {
                  "keyword_slug": {
                    "type": "string"
                  },
                  "actual_result": {
                    "type": "string"
                  },
                  "months_elapsed": {
                    "type": "integer"
                  },
                  "traffic_achieved": {
                    "type": "integer"
                  },
                  "notes": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Default Response",
